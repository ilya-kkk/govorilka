TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OPENROUTER_CHAT_MODEL=openai/gpt-oss-120b:free
OPENROUTER_STT_MODEL=openai/gpt-4o-mini-transcribe
OPENROUTER_TTS_MODEL=hexgrad/kokoro-82m
OPENROUTER_TTS_VOICE=af_heart
OPENROUTER_TTS_SPEED=1.0

DATABASE_URL=sqlite+aiosqlite:///./data/bot.sqlite3

MAX_CONTEXT_MESSAGES=30
MAX_REVIEW_MESSAGES=100
QUESTION_BANK_PATH=./questions.json
QUESTION_BANK_INCLUDE_BUILTIN=false
REMINDER_TIMEZONE=UTC
REMINDER_CHECK_INTERVAL_SECONDS=30

# Optional comma-separated numeric Telegram user IDs. If empty, allow any private-chat user.
# Telegram usernames are not supported here because they can change.
ALLOWED_TELEGRAM_USER_IDS=
